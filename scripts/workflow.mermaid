---
config:
  flowchart:
    curve: linear
---
graph TD;
	__start__([<p>__start__</p>]):::first
	load_data(load_data)
	rule_engine_batch(rule_engine_batch)
	write_results(write_results)
	__end__([<p>__end__</p>]):::last
	__start__ --> load_data;
	load_data --> rule_engine_batch;
	rule_engine_batch --> write_results;
	write_results --> __end__;
	classDef default fill:#f2f0ff,line-height:1.2
	classDef first fill-opacity:0
	classDef last fill:#bfb6fc
